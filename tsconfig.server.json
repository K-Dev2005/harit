{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/server/**/*", "src/lib/**/*"],
  "exclude": ["node_modules", "src/components/**/*", "src/pages/**/*", "src/main.tsx", "src/App.tsx", "**/*.test.ts"]
}
